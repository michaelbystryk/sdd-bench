+from __future__ import annotations
+
+from fastapi import APIRouter, Depends
+
+from ..deps import get_loan_service
+from ..schemas import LoanCreate, LoanRead
+from ..services import LoanService
+
+router = APIRouter(prefix="/loans", tags=["loans"])
+
+
+@router.post("", response_model=LoanRead, status_code=201)
+def checkout(data: LoanCreate, service: LoanService = Depends(get_loan_service)) -> LoanRead:
+    return LoanRead.model_validate(service.checkout(data))
+
+
+@router.post("/{loan_id}/return", response_model=LoanRead)
+def return_loan(loan_id: int, service: LoanService = Depends(get_loan_service)) -> LoanRead:
+    return LoanRead.model_validate(service.return_loan(loan_id))

