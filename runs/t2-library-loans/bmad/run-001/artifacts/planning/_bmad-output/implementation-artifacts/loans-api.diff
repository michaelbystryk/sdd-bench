+class LoanService:
+    """Lending logic. Validates identities and eligibility, then mutates the
+    shared ``Book`` entity's availability. Reuses ``BookService``/``MemberService``
+    so not-found handling stays in one place."""
+
+    def __init__(
+        self, repo: LoanRepository, books: BookService, members: MemberService
+    ) -> None:
+        self.repo = repo
+        self.books = books
+        self.members = members
+
+    def checkout(self, data: LoanCreate) -> Loan:
+        book = self.books.get_book(data.book_id)
+        self.members.get_member(data.member_id)
+
+        active = self.repo.list_for_member(data.member_id, status=LoanStatus.ACTIVE)
+        if len(active) >= MAX_ACTIVE_LOANS:
+            raise ConflictError(
+                f"Member {data.member_id} already holds {MAX_ACTIVE_LOANS} active loans",
+                code="loan_limit_exceeded",
+            )
+        if book.available_copies <= 0:
+            raise ConflictError(
+                f"No copies of book {book.id} are available",
+                code="no_copies_available",
+            )
+
+        book.available_copies -= 1
+        return self.repo.add(Loan(id=0, book_id=book.id, member_id=data.member_id))
+
+    def return_loan(self, loan_id: int) -> Loan:
+        loan = self.repo.get(loan_id)
+        if loan is None:
+            raise NotFoundError(f"Loan {loan_id} not found")
+        if loan.status == LoanStatus.RETURNED:
+            raise ConflictError(f"Loan {loan_id} already returned", code="already_returned")
+
+        loan.status = LoanStatus.RETURNED
+        loan.returned_at = datetime.now(timezone.utc)
+        self.books.get_book(loan.book_id).available_copies += 1
+        return loan
+
+    def list_member_loans(
+        self, member_id: int, *, status: LoanStatus | None = None
+    ) -> list[Loan]:
+        self.members.get_member(member_id)
+        return self.repo.list_for_member(member_id, status=status)

