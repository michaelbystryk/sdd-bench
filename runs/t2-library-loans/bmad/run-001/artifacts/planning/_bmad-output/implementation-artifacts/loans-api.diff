+@router.get("/{member_id}/loans", response_model=Page[LoanRead])
+def list_member_loans(
+    member_id: int,
+    status: LoanStatus | None = None,
+    limit: int = Query(DEFAULT_PAGE_LIMIT, ge=1, le=MAX_PAGE_LIMIT),
+    offset: int = Query(0, ge=0),
+    service: LoanService = Depends(get_loan_service),
+) -> Page[LoanRead]:
+    loans = service.list_member_loans(member_id, status=status)
+    page_items, total = paginate(loans, limit=limit, offset=offset)
+    return Page[LoanRead](
+        items=[LoanRead.model_validate(loan) for loan in page_items],
+        total=total,
+        limit=limit,
+        offset=offset,
+    )

