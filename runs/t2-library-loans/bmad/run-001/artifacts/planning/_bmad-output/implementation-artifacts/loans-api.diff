@@ appended after MemberRepository @@
+class LoanRepository:
+    def __init__(self) -> None:
+        self._items: dict[int, Loan] = {}
+        self._next_id = 1
+
+    def add(self, loan: Loan) -> Loan:
+        loan.id = self._next_id
+        self._items[loan.id] = loan
+        self._next_id += 1
+        return loan
+
+    def get(self, loan_id: int) -> Loan | None:
+        return self._items.get(loan_id)
+
+    def list_for_member(
+        self, member_id: int, *, status: LoanStatus | None = None
+    ) -> list[Loan]:
+        items = [loan for loan in self._items.values() if loan.member_id == member_id]
+        if status is not None:
+            items = [loan for loan in items if loan.status == status]
+        return items

